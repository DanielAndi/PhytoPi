[Unit]
Description=PhytoPi Flutter Kiosk UI
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
User=phytopi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/phytopi/.Xauthority
Environment=BUNDLE=/home/phytopi/PhytoPi/User_Interface/build/linux/arm64/release/bundle
WorkingDirectory=/home/phytopi/PhytoPi/User_Interface/build/linux/arm64/release/bundle
ExecStart=/home/phytopi/PhytoPi/User_Interface/build/linux/arm64/release/bundle/phytopi_dashboard
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
