# Copy this file to .env (next to docker-compose.server.yml) and fill in values.
# This file is used by the AI worker running on your home server/PC.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
# Service role key is required so the worker can bypass RLS when writing results
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# ── Ollama ────────────────────────────────────────────────────────────────────
# Where Ollama is listening on the host. The default works on Linux/Mac when
# Ollama is running natively; on Windows use http://localhost:11434.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=moondream:1.8b

# ── PlantNet (optional species ID fallback) ───────────────────────────────────
PLANTNET_API_KEY=
PLANTNET_CONFIDENCE_THRESHOLD=0.20
